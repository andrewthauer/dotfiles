{
  "agent": {
    "profiles": {},
    "use_modifier_to_send": true
  },
  "buffer_font_size": 15,
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "provider": "none",
    "mode": "eager"
  },
  "ensure_final_newline_on_save": true,
  "file_types": {
    "Dockerfile": [
      "**/Dockerfile*"
    ],
    "env": [
      "*.env",
      ".env.*",
      "*.conf"
    ],
    "Git Config": [
      "**/git/config*",
      "**/git/aliases*"
    ],
    "Git Ignore": [
      "**/git/ignore*",
      "dockerignore"
    ],
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml"
    ],
    "ini": [
      "**/git/config*",
      "**/git/aliases*"
    ],
    "Markdown": [
      "*.rules",
      "*.mdc"
    ],
    "Shell Script": [
      "**/*.bats"
    ],
    "XML": [
      "*.plist"
    ]
  },
  "file_scan_exclusions": [
    ".git/*",
    ".jj/*",
    "**/node_modules/**"
  ],
  "format_on_save": "off",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Frappé"
  },
  "inlay_hints": {
    "enabled": true
  },
  "languages": {
    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "!solargraph"
      ]
    }
  },
  "lsp": {
    "ruby-lsp": {
      "binary": {
        "path": "mise",
        "arguments": [
          "exec",
          "--",
          "ruby-lsp"
        ]
      },
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      },
      "settings": {
        "use_bundler": false,
        "rubyVersionManager": "mise"
      }
    }
  },
  "search": {
    "include_ignored": false
  },
  "ssh_connections": [
    {
      "host": "hass",
      "projects": [
        {
          "paths": [
            "~",
            "/root/config"
          ]
        }
      ]
    },
    {
      "host": "nas",
      "projects": [
        {
          "paths": [
            "~",
            "/volume1/docker"
          ]
        }
      ]
    }
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 15,
    "option_as_meta": true,
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "theme": "Catppuccin Frappé",
  "ui_font_family": "FiraCode Nerd Font Propo",
  "ui_font_size": 15,
  "use_system_window_tabs": true,
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": false
  },
  "which_key": {
    "delay_ms": 750,
    "enabled": true
  }
}